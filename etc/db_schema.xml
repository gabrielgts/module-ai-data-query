<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="gtstudio_ai_entities" resource="default" engine="innodb" comment="Queryable entities registry">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true"
                comment="Entity Id"/>
        <column xsi:type="varchar" name="code" nullable="false" length="255" comment="Entity code (e.g. sales_order)"/>
        <column xsi:type="varchar" name="label" nullable="false" length="255" comment="Display label"/>
        <column xsi:type="text" name="description" nullable="true" comment="Description of the entity"/>
        <column xsi:type="varchar" name="collection_class" nullable="false" length="255" comment="Collection class path"/>
        <column xsi:type="text" name="searchable_fields" nullable="false" comment="JSON array of queryable fields"/>
        <column xsi:type="text" name="filterable_fields" nullable="true" comment="JSON array of filterable fields"/>
        <column xsi:type="text" name="sortable_fields" nullable="true" comment="JSON array of sortable fields"/>
        <column xsi:type="int" name="max_results" nullable="false" default="100" comment="Maximum results per query"/>
        <column xsi:type="tinyint" name="is_active" nullable="false" default="1" comment="Is entity queryable"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="GTSTUDIO_AI_ENTITIES_CODE_UNIQUE">
            <column name="code"/>
        </constraint>
        <index referenceId="GTSTUDIO_AI_ENTITIES_IS_ACTIVE" indexType="btree">
            <column name="is_active"/>
        </index>
    </table>
</schema>
